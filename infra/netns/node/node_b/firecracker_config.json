{
  "boot-source": {
    "kernel_image_path": "/data/firecracker/vmlinux",
    "boot_args": "console=ttyS0 root=/dev/vda rootfstype=ext4 reboot=k panic=1 rw"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "/data/firecracker/node_b/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": {
    "vcpu_count": 2,
    "mem_size_mib": 1024
  },
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "guest_mac": "06:00:AC:10:00:01",
      "host_dev_name": "tap0"
    }
  ]
}
